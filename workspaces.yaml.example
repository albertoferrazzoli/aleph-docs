# Aleph Docs — workspaces configuration.
# Each entry defines a (docs folder, embedder backend, Postgres DB)
# triplet. MCP boots on the persisted active workspace or the first
# one in this list. Switch at runtime via the `switch_workspace` MCP
# tool or the workspace selector in the aleph viewer.
#
# Leaving this file absent falls back to legacy single-workspace
# behavior driven by .env vars.
#
# Two concrete profiles below — organise your `./docs/` with a
# subfolder per workspace (e.g. `./docs/trading/` and `./docs/babel/`)
# and point each docs_path at the container-side subpath.

- name: trading_course
  docs_path: /docs/trading
  backend: nomic_multimodal_local
  dim: 768
  pg_db: aleph_memory            # reuse the default DB when migrating
  hybrid: true

- name: babel
  docs_path: /docs/babel
  backend: nomic_multimodal_local
  dim: 768
  pg_db: aleph_babel
  hybrid: true

# Example alternative — zero-cost text-only with Ollama:
#
# - name: company_docs
#   docs_path: /docs/company
#   backend: local
#   dim: 1024
#   pg_db: aleph_company
#   hybrid: false
#   local_embed_dim: 1024
