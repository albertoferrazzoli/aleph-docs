# Secrets
.env
*.env
!.env.example
*.htpasswd

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/

# Node / Vite
node_modules/
dist/
.vite/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Runtime state (deploy scripts preserve these on the VM, but they
# should never live in the template repo)
repo/
data/
*.db
*.sqlite
*.sqlite3

# User documentation content — the ./docs/ folder is bind-mounted
# into containers at runtime. Only the template placeholders
# (README.md + guides/getting-started.md) ship with the repo;
# everything else is user-owned and must not be committed.
docs/*
!docs/README.md
!docs/guides/
docs/guides/*
!docs/guides/getting-started.md
.DS_Store

# Logs + backups
*.log
*.bak
*.bak.*
.worktrees/
