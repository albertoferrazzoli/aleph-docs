# ==========================================================
# Aleph Docs — Docker stack configuration
# Copy to .env and fill every ? value before `docker compose up`.
# ==========================================================

# --- Secrets (required) ---
# Generate each with:  openssl rand -hex 32
MCP_API_KEY=
ALEPH_API_KEY=

# --- Postgres (optional override; any value works, Docker creates the DB) ---
PG_USER=aleph
PG_DB=aleph_memory
PG_PASSWORD=aleph_dev_password_change_me

# --- Embedding backend ---
# Options:
#   gemini-001        → text-only, cheapest cloud (default). Needs GOOGLE_API_KEY.
#   gemini-2-preview  → multimodal (text + image + video + audio + pdf). Needs GOOGLE_API_KEY.
#   local             → offline via Ollama. Needs a running Ollama reachable at OLLAMA_HOST.
EMBED_BACKEND=gemini-001
EMBED_DIM=1536
GOOGLE_API_KEY=

# Only used if EMBED_BACKEND=local. Run Ollama on the host and the MCP
# container will reach it at host.docker.internal:11434 (on Mac/Win) or
# point OLLAMA_HOST at a full URL.
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=bge-m3
LOCAL_EMBED_DIM=1024

# --- Docs source ---
# Two mutually exclusive change-detection modes:
#   * DOCS_REPO_URL empty (default) → LOCAL / FILESYSTEM MODE:
#       ./docs/ is bind-mounted into the mcp container and the reconciler
#       watches it with watchdog. Add / update / delete detected in real
#       time (2 s debounce). Best for solo dev + the Docker quick start.
#   * DOCS_REPO_URL set → GIT MODE:
#       The indexer clones the remote repo into mcp_data and uses
#       `git diff` between commits to drive the reconcile. No filesystem
#       watcher. Best for teams where docs have their own review cycle.
DOCS_REPO_URL=
DOCS_REPO_BRANCH=main
DOCS_REPO_TOKEN=
# If your markdown lives under docs/content/ (Nextra-style) set this to
# "content". For a flat docs/ layout, leave empty.
CONTENT_SUBDIR=

# Background media reconciler — only relevant when EMBED_BACKEND supports
# images/video/audio/pdf (e.g. gemini-2-preview). Set to false to skip
# the first-boot scan entirely; you can still trigger it on demand via
# the MCP tool `reindex_docs()`.
INGEST_MEDIA_ON_BOOT=true

# --- Auto-rebuild of the viewer's 3D graph snapshot ---
# The aleph container listens for `memory_change` NOTIFY and rebuilds
# the UMAP snapshot with a two-policy debounce:
#   - PROJECTION_DEBOUNCE_S  : rebuild after N seconds of quiet
#   - PROJECTION_MAX_STALE_S : force rebuild at least every N seconds
#                              during a long ingest burst
# Set AUTO_PROJECTION=false to disable and rebuild manually with
#   docker compose exec aleph python -m backend.projection
AUTO_PROJECTION=true
PROJECTION_DEBOUNCE_S=30
PROJECTION_MAX_STALE_S=120

# --- Optional: propose_doc_patch(open_pr=true) ---
# A fine-grained GitHub PAT with contents + pull-requests write scope
# on the docs repo. Leave empty to disable PR opening; local branch +
# commit still work.
DOCS_WRITE_TOKEN=

# --- Lint cadence ---
LINT_MODE=auto

# --- Port mappings (edit if 8001 / 8765 are taken on your host) ---
MCP_PORT=8001
ALEPH_PORT=8765

# --- Logging ---
LOG_LEVEL=INFO
