# ================================================================
# Aleph Docs — top-level environment template
#
# Copy to .env and fill every value. .env is read by both deploy
# scripts (mcp/deploy-mcp.sh and aleph/deploy-aleph.sh) and must
# stay out of git (.gitignore covers it).
# ================================================================

# ---- Where your docs live ----
#
# Two modes, mutually exclusive:
#
#  A) LOCAL MODE (default, zero config): leave DOCS_REPO_URL empty. The
#     indexer reads .md/.mdx files from the local `docs/` folder in this
#     repo (or LOCAL_DOCS_PATH if set). Perfect for getting started quickly
#     or when docs live next to the app.
#
#  B) REMOTE-REPO MODE: set DOCS_REPO_URL to a git repo. The indexer
#     clones / pulls it into mcp/repo/ and uses `git diff` for incremental
#     updates. Preferred for larger teams where docs have their own
#     review cycle.
#
DOCS_REPO_URL=
DOCS_REPO_BRANCH=main
# A fine-grained or classic PAT with `repo: read` scope — only if you set
# DOCS_REPO_URL to a private repo.
DOCS_REPO_TOKEN=
# Path to the local docs root (used only in local mode). Default: ./docs
# relative to the repo root.
LOCAL_DOCS_PATH=
# Name of the subdirectory holding markdown inside the docs root. Nextra /
# Docusaurus use "content". For a flat layout, set to empty string.
CONTENT_SUBDIR=content

# ---- (Optional) GitHub PAT with WRITE scope on the docs repo ----
# Enables `propose_doc_patch(open_pr=true)`. Safe to leave empty —
# the tool will still produce local branches + commits without push.
DOCS_WRITE_TOKEN=

# ---- Embeddings (pluggable backends — see PRD_MULTIMODAL §5.0) ----
# Pick one: gemini-001 (default, text-only, cheapest cloud)
#           gemini-2-preview (multimodal: text+image+video+audio+pdf)
#           local (offline via Ollama)
EMBED_BACKEND=gemini-001
EMBED_DIM=1536

# Gemini (Generative Language API): required for gemini-* backends.
GOOGLE_API_KEY=
# Optional override of the model id used by the active backend.
EMBED_MODEL=

# Local backend (Ollama). Only used when EMBED_BACKEND=local.
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=bge-m3
LOCAL_EMBED_DIM=1024

# ---- PostgreSQL ----
# Created in step 3 of SETUP.md. Keep them in sync.
PG_PASSWORD=
PG_DSN=postgresql://aleph:REPLACE_ME@localhost:5432/aleph_memory
PG_POOL_MAX=10

# Master switch. false => the MCP runs without the memory layer
# (only FTS5 lexical search works). Useful for emergencies.
MEMORY_ENABLED=true

# ---- MCP server ----
# Secret used by the MCP bearer-token middleware. Clients must send
# `Authorization: Bearer <value>` on every request.
MCP_API_KEY=
MCP_HOST=127.0.0.1
MCP_PORT=8001
# Cosmetic — appears in health + logs.
MCP_SERVER_NAME=AlephDocs

# ---- Aleph viewer ----
# Secret required only for WRITE endpoints (remember / forget) via
# the `X-Aleph-Key` header. Read endpoints are gated by Apache Basic Auth.
ALEPH_API_KEY=
ALEPH_HOST=127.0.0.1
ALEPH_PORT=8765

# Apache Basic Auth credentials for /aleph/*. The deploy script
# writes them to /etc/apache2/aleph.htpasswd (bcrypt).
HTPASSWD_USER=admin
HTPASSWD_PASSWORD=

# ---- Target VM (only used by the deploy scripts) ----
# These defaults assume GCP; swap to a plain SSH host if you don't
# use gcloud. The scripts gracefully accept either.
PROD_VM=aleph-vm
PROD_ZONE=europe-west1-d
PROD_PROJECT=

# ---- Lint cadence (optional tuning) ----
# See mcp/memory/lint.py for defaults. These are safe starting points.
LINT_MODE=auto
LINT_INTERVAL_HOURS=6
LINT_MIN_WRITES=5
LINT_FULL_INTERVAL_HOURS=168
LINT_MAX_PAIRS=20
# Set to true to record a memory_audit row for EVERY search-hit
# reinforcement. Very noisy at scale; off by default.
AUDIT_REINFORCE=false

# ---- (Optional) CLI / error / API section scoping ----
# If you have a convention like "all CLI docs live under /cli/",
# set the prefix here to scope the find_command_line_option helper.
CLI_SUBTREES=
ERROR_SECTION=
API_SECTION=

# ---- Debug ----
LOG_LEVEL=INFO
