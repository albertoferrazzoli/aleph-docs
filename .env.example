# ================================================================
# Aleph Docs — top-level environment template
#
# Copy to .env and fill every value. .env is read by both deploy
# scripts (mcp/deploy-mcp.sh and aleph/deploy-aleph.sh) and must
# stay out of git (.gitignore covers it).
# ================================================================

# ---- Where your docs live ----
#
# Two mutually exclusive change-detection modes, selected by whether
# DOCS_REPO_URL is set. Both are incremental and idempotent (SHA-256 +
# `mtime` fast path), so re-running the reconciler never re-embeds
# unchanged content.
#
#  A) LOCAL / FILESYSTEM MODE (default): leave DOCS_REPO_URL empty. The
#     indexer reads files directly from the local `docs/` folder (or
#     LOCAL_DOCS_PATH if set). At boot it walks the tree and diffs
#     against the `memories` table by source_path + hash; at runtime a
#     watchdog-based filesystem watcher picks up add/update/delete events
#     with a 2 s debounce. Best for solo dev and the Docker quick start.
#
#  B) GIT MODE: set DOCS_REPO_URL to a git repo. The indexer clones /
#     pulls into mcp/repo/ and uses `git diff --name-status` between the
#     last indexed commit and HEAD to drive the reconcile — precise,
#     no watcher needed (git is the source of truth). Best for larger
#     teams where docs have their own review cycle.
#
DOCS_REPO_URL=
DOCS_REPO_BRANCH=main
# A fine-grained or classic PAT with `repo: read` scope — only if you set
# DOCS_REPO_URL to a private repo.
DOCS_REPO_TOKEN=
# Path to the local docs root (used only in filesystem mode). Default:
# ./docs relative to the repo root.
LOCAL_DOCS_PATH=
# Name of the subdirectory holding files inside the docs root. Nextra /
# Docusaurus repos use "content". For a flat layout leave empty.
CONTENT_SUBDIR=content

# Media reconciler: set false to skip the first-boot scan of images/
# videos/audio/pdf. The watcher (filesystem mode) and the `reindex_docs`
# MCP tool remain available on demand either way.
INGEST_MEDIA_ON_BOOT=true

# Hybrid media embedding. Default true: per scene/clip/page emit a
# paired multimodal row (video_scene / audio_clip / pdf_page) AND a
# text row (video_transcript / audio_transcript / pdf_text). Set false
# to keep only the text rows — the ingest becomes zero-cost when
# combined with EMBED_BACKEND=local (Ollama) and whisper_local ASR.
HYBRID_MEDIA_EMBEDDING=true

# ---- ASR (speech-to-text for videos + audio) ----
# When active, each video scene / audio clip is transcribed and the
# transcript is stored as a paired kind=video_transcript /
# audio_transcript row (text embedding). That makes "what does the
# instructor say about X?" queryable via semantic_search.
#
# Backends:
#   whisper_local : free, local. Uses a whisper.cpp HTTP server on the
#                   host (Metal on Apple Silicon) when ASR_HOST is set;
#                   otherwise falls back to faster-whisper on CPU in
#                   the container (~0.5x realtime — slow for bulk).
#   openai        : whisper-1, $0.006/min. Requires OPENAI_API_KEY.
#   gemini        : gemini-2.5-flash audio, ~$0.01/min. Reuses GOOGLE_API_KEY.
ASR_BACKEND=whisper_local
ASR_ENABLED=true
# ISO-639-1 code. Leave empty to auto-detect.
ASR_LANGUAGE=
ASR_TIMEOUT_S=600
# whisper_local: URL of a whisper.cpp HTTP server on the host.
#   macOS / Windows Docker Desktop: http://host.docker.internal:8090
#   Linux default bridge:           http://172.17.0.1:8090
ASR_HOST=
ASR_MODEL=large-v3
# openai backend
OPENAI_API_KEY=
ASR_OPENAI_MODEL=whisper-1
# gemini backend
ASR_GEMINI_MODEL=gemini-2.5-flash

# Auto-rebuild of the aleph viewer's 3D snapshot. Rebuilds on quiet
# (PROJECTION_DEBOUNCE_S) or at a maximum interval during bursts
# (PROJECTION_MAX_STALE_S). Set AUTO_PROJECTION=false to disable and
# invoke `python -m backend.projection` manually.
AUTO_PROJECTION=true
PROJECTION_DEBOUNCE_S=30
PROJECTION_MAX_STALE_S=120

# ---- (Optional) GitHub PAT with WRITE scope on the docs repo ----
# Enables `propose_doc_patch(open_pr=true)`. Safe to leave empty —
# the tool will still produce local branches + commits without push.
DOCS_WRITE_TOKEN=

# ---- Embeddings (pluggable backends — see PRD_MULTIMODAL §5.0) ----
# Pick one: gemini-001             (default, text-only, cheapest cloud)
#           gemini-2-preview       (multimodal: text+image+video+audio+pdf)
#           local                  (offline via Ollama, text-only)
#           nomic_multimodal_local (offline text+image, via host server;
#                                   see docs/EMBED_NOMIC_SETUP.md)
EMBED_BACKEND=gemini-001
EMBED_DIM=1536

# Gemini (Generative Language API): required for gemini-* backends.
GOOGLE_API_KEY=
# Optional override of the model id used by the active backend.
EMBED_MODEL=

# Local backend (Ollama). Only used when EMBED_BACKEND=local.
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=bge-m3
LOCAL_EMBED_DIM=1024

# Nomic multimodal local backend. Only used when
# EMBED_BACKEND=nomic_multimodal_local. Requires the host-side server
# from docker/nomic-embed-server/ to be running (see
# docs/EMBED_NOMIC_SETUP.md — ~2 GB weight download on first start).
# For the zero-cost multimodal combo, set:
#   EMBED_BACKEND=nomic_multimodal_local
#   EMBED_DIM=768
#   HYBRID_MEDIA_EMBEDDING=true
# Host URL as reachable from the mcp container:
#   macOS / Windows (Docker Desktop) : http://host.docker.internal:8091
#   Linux (default docker0 bridge)   : http://172.17.0.1:8091
EMBED_NOMIC_HOST=http://host.docker.internal:8091
EMBED_NOMIC_TIMEOUT_S=60

# ---- PostgreSQL ----
# Created in step 3 of SETUP.md. Keep them in sync.
PG_PASSWORD=
PG_DSN=postgresql://aleph:REPLACE_ME@localhost:5432/aleph_memory
PG_POOL_MAX=10

# Master switch. false => the MCP runs without the memory layer
# (only FTS5 lexical search works). Useful for emergencies.
MEMORY_ENABLED=true

# ---- MCP server ----
# Secret used by the MCP bearer-token middleware. Clients must send
# `Authorization: Bearer <value>` on every request.
MCP_API_KEY=
MCP_HOST=127.0.0.1
MCP_PORT=8001
# Cosmetic — appears in health + logs.
MCP_SERVER_NAME=AlephDocs

# ---- Aleph viewer ----
# Secret required only for WRITE endpoints (remember / forget) via
# the `X-Aleph-Key` header. Read endpoints are gated by Apache Basic Auth.
ALEPH_API_KEY=
ALEPH_HOST=127.0.0.1
ALEPH_PORT=8765

# Apache Basic Auth credentials for /aleph/*. The deploy script
# writes them to /etc/apache2/aleph.htpasswd (bcrypt).
HTPASSWD_USER=admin
HTPASSWD_PASSWORD=

# ---- Target VM (only used by the deploy scripts) ----
# These defaults assume GCP; swap to a plain SSH host if you don't
# use gcloud. The scripts gracefully accept either.
PROD_VM=aleph-vm
PROD_ZONE=europe-west1-d
PROD_PROJECT=

# ---- Lint cadence (optional tuning) ----
# See mcp/memory/lint.py for defaults. These are safe starting points.
LINT_MODE=auto
LINT_INTERVAL_HOURS=6
LINT_MIN_WRITES=5
LINT_FULL_INTERVAL_HOURS=168
LINT_MAX_PAIRS=20
# Set to true to record a memory_audit row for EVERY search-hit
# reinforcement. Very noisy at scale; off by default.
AUDIT_REINFORCE=false

# ---- (Optional) CLI / error / API section scoping ----
# If you have a convention like "all CLI docs live under /cli/",
# set the prefix here to scope the find_command_line_option helper.
CLI_SUBTREES=
ERROR_SECTION=
API_SECTION=

# ---- Debug ----
LOG_LEVEL=INFO
